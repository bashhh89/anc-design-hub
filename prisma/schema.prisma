// ANC Design Hub — data model
// Sales-support design workflow. Talks to the CRM (Twenty) for Opportunity briefs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
  SALES
}

enum Category {
  INTERNAL
  EXTERNAL
}

enum ProjectType {
  DEVELOPMENT
  DESIGN
  ENGINEERING
  MARKETING
  OTHER
}

enum Status {
  REQUEST
  BRIEF
  IN_PROGRESS
  REVIEW
  REVISIONS
  APPROVED
  DELIVERED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      Role     @default(MEMBER)
  color     String   @default("#5a4be0")
  createdAt DateTime @default(now())

  ledProjects   Project[]    @relation("TeamLead")
  createdProjects Project[]  @relation("Creator")
  assignedItems Project[]    @relation("Assignees")
  comments      Comment[]
  revisions     Revision[]
  activity      Activity[]
  attachments   Attachment[]
  voiceNotes    VoiceNote[]
}

// A board is a flexible workspace Daniel creates and categorizes.
model Board {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#5a4be0")
  icon      String?
  order     Int      @default(0)
  groups    Group[]
  items     Project[]
  statuses  StatusOption[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

// A group is a colored section inside a board (Monday-style).
model Group {
  id      String  @id @default(cuid())
  board   Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  name    String
  color   String  @default("#5a4be0")
  order   Int     @default(0)
  collapsed Boolean @default(false)
  items   Project[]

  @@index([boardId])
}

// Editable status label + color, scoped to a board (New / Working / Review / Stuck / Done…).
model StatusOption {
  id      String  @id @default(cuid())
  board   Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  label   String
  color   String
  order   Int     @default(0)
  items   Project[]

  @@index([boardId])
}

model Project {
  id          String      @id @default(cuid())
  name        String
  category    Category    @default(EXTERNAL)
  type        ProjectType @default(DESIGN)
  status      Status      @default(REQUEST) // legacy enum — kept in sync with statusOption during transition
  priority    Priority    @default(MEDIUM)
  description String?     @db.Text
  notes       String?     @db.Text
  dueDate     DateTime?   // "Date" column
  startDate   DateTime?   // "Timeline" column start
  endDate     DateTime?   // "Timeline" column end
  order       Int         @default(0)

  // CRM linkage — the brief can originate from a Twenty Opportunity
  crmOpportunityId   String?
  crmOpportunityName String?

  // Board / group / dynamic status (Monday-style)
  board          Board?        @relation(fields: [boardId], references: [id])
  boardId        String?
  group          Group?        @relation(fields: [groupId], references: [id])
  groupId        String?
  statusOption   StatusOption? @relation(fields: [statusOptionId], references: [id])
  statusOptionId String?

  teamLead    User?   @relation("TeamLead", fields: [teamLeadId], references: [id])
  teamLeadId  String?
  assignees   User[]  @relation("Assignees")
  createdBy   User    @relation("Creator", fields: [createdById], references: [id])
  createdById String

  brief       Brief?
  attachments Attachment[]
  comments    Comment[]
  revisions   Revision[]
  activity    Activity[]
  voiceNotes  VoiceNote[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // soft-delete — no hard delete, ever (Daniel's rule)

  @@index([status])
  @@index([deletedAt])
  @@index([boardId])
  @@index([groupId])
}

// Forced structured intake — Sales must fill this before a request becomes work.
model Brief {
  id           String   @id @default(cuid())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String   @unique
  deliverables String   @db.Text
  references   String?  @db.Text
  deadline     DateTime?
  emailLink    String?
  teamsLink    String?
  submittedBy  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Attachment {
  id           String   @id @default(cuid())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  name         String
  url          String
  mime         String?
  size         Int?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  createdAt    DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
}

model Revision {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  label       String
  note        String?  @db.Text
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())
}

// Audit trail — who did what, when. Append-only.
model Activity {
  id        String   @id @default(cuid())
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  action    String
  detail    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

// V2 surface — recorded now in the model so the schema is stable.
model VoiceNote {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  audioUrl    String
  transcript  String?  @db.Text
  summary     String?  @db.Text
  durationSec Int?
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())
}
